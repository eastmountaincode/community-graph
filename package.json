{
  "name": "bandwidth-vs-irl",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "wrangler dev --persist-to \"$HOME/.cache/bandwidth-vs-irl/wrangler-state\"",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "d1:migrate:local": "wrangler d1 migrations apply bandwidth-vs-irl --local --persist-to \"$HOME/.cache/bandwidth-vs-irl/wrangler-state\"",
    "d1:migrate:remote": "wrangler d1 migrations apply bandwidth-vs-irl --remote"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.20.1",
    "@playhtml/react": "^1.0.0",
    "@xyflow/react": "^12.11.1",
    "next": "16.2.9",
    "playhtml": "^2.11.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260629.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wrangler": "^4.105.0"
  }
}
